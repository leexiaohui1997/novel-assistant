{
  "name": "novel-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.19.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,less,scss}\"",
    "type-check": "tsc -b --noEmit",
    "prepare": "husky install",
    "release": "node scripts/create-release-tag.js"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@reduxjs/toolkit": "^2.0.1",
    "@tauri-apps/api": "^2.0.0",
    "antd": "^6.3.6",
    "dayjs": "^1.11.20",
    "lodash-es": "^4.18.1",
    "loglevel": "^1.9.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.0.4",
    "react-router-dom": "^7.14.1",
    "slate": "^0.124.1",
    "slate-history": "^0.113.1",
    "slate-react": "^0.124.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@inquirer/prompts": "^8.4.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^6.0.1",
    "commander": "^14.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "15",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ],
    "src-tauri/**/*.rs": [
      "bash -c 'cd src-tauri && cargo fmt'"
    ]
  }
}
